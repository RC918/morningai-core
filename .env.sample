# MorningAI Core API Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
# Use pure libpq format with sslmode=require for Render/Supabase
# Format: postgres://username:password@hostname:port/database?sslmode=require
DATABASE_URL=postgres://username:password@hostname:5432/database?sslmode=require

# Application Environment
ENV=staging
LOG_LEVEL=info

# Optional: OpenAI API Key (if needed for AI features)
# OPENAI_API_KEY=your_openai_api_key_here

# Note: For Render deployment, these variables are set in the Render dashboard
# Do not include actual credentials in this file

