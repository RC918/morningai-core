# MorningAI Phase 5 環境配置範例

# 應用程序配置
APP_NAME=MorningAI
APP_VERSION=3.0.0-phase5-chat-beta
APP_ENV=development
DEBUG=true

# 服務端口
API_PORT=8000
DB_PORT=5432
REDIS_PORT=6379

# 資料庫配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/morningai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=morningai
DB_USER=postgres
DB_PASSWORD=postgres

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI 配置 (必須設置)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# RAG 配置
RAG_ENABLED=true
RAG_SIMILARITY_THRESHOLD=0.7
RAG_MAX_RESULTS=5
RAG_FALLBACK_TO_GPT=true

# 向量數據庫配置 (pgvector)
VECTOR_DB_ENABLED=false
VECTOR_DIMENSION=1536
VECTOR_INDEX_TYPE=hnsw
VECTOR_SIMILARITY_METRIC=cosine

# 速率限制配置
RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT=30  # 每小時聊天次數
GPT_RATE_LIMIT=20   # 每小時GPT調用次數
RATE_LIMIT_STORAGE=redis

# 緩存配置
CACHE_ENABLED=true
CACHE_TTL=3600  # 1小時
CACHE_PREFIX=morningai:cache:

# 日誌配置
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# 安全配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_COOKIES=false
HTTPS_ONLY=false

# 監控配置
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
PROMETHEUS_ENABLED=false

# 租戶配置
MULTI_TENANT_ENABLED=true
DEFAULT_TENANT=demo

# 文件上傳配置
UPLOAD_MAX_SIZE=10485760  # 10MB
UPLOAD_ALLOWED_TYPES=txt,pdf,docx,md

# 郵件配置 (可選)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# 第三方集成 (可選)
TELEGRAM_BOT_TOKEN=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 開發工具配置
RELOAD=true
WORKERS=1
ACCESS_LOG=true

# 測試配置
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/morningai_test
TEST_REDIS_URL=redis://localhost:6379/1

