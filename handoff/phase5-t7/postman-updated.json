{
  "info": {
    "name": "MorningAI Core API - T+7 Vector Integration",
    "description": "MorningAI 核心 API 測試集合 - 包含向量庫整合和 RAG 系統測試\n\n## 🚀 新功能測試 (T+7 更新)\n- ✅ 向量語義搜索測試\n- ✅ 增強聊天對話測試\n- ✅ 知識庫管理測試\n- ✅ 評測系統測試\n- ✅ 系統健康檢查\n\n## 📊 測試覆蓋\n- 認證系統: 7 個端點\n- 推薦系統: 8 個端點\n- 聊天系統: 12 個端點 (新增)\n- 知識管理: 5 個端點 (新增)\n- 評測系統: 3 個端點 (新增)\n- 系統監控: 1 個端點\n\n總計: 36 個測試請求",
    "version": "3.1.0-t7",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "session_id",
      "value": "test-session-{{$randomUUID}}",
      "type": "string"
    },
    {
      "key": "evaluation_id",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// 全局前置腳本",
          "console.log('🚀 執行請求:', pm.info.requestName);",
          "console.log('📍 URL:', pm.request.url.toString());"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// 全局測試腳本",
          "pm.test('響應時間 < 5秒', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "pm.test('響應格式為 JSON', function () {",
          "    pm.response.to.have.header('Content-Type');",
          "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});",
          "",
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "    pm.test('成功響應包含必要字段', function () {",
          "        const responseJson = pm.response.json();",
          "        pm.expect(responseJson).to.be.an('object');",
          "    });",
          "}",
          "",
          "console.log('✅ 響應狀態:', pm.response.code, pm.response.status);",
          "console.log('⏱️  響應時間:', pm.response.responseTime + 'ms');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "🔐 認證系統",
      "item": [
        {
          "name": "用戶登入",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const responseJson = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', responseJson.access_token);",
                  "    console.log('🔑 已保存 access_token');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@morningai.com\",\n  \"password\": \"user123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "獲取用戶資料",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/profile",
              "host": ["{{base_url}}"],
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "🔍 向量搜索系統",
      "item": [
        {
          "name": "向量語義搜索 - 定價查詢",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('搜索結果不為空', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.results).to.be.an('array');",
                  "    pm.expect(responseJson.results.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('相似度分數合理', function () {",
                  "    const responseJson = pm.response.json();",
                  "    responseJson.results.forEach(result => {",
                  "        pm.expect(result.similarity).to.be.within(0, 1);",
                  "    });",
                  "});",
                  "",
                  "pm.test('查詢時間 < 1秒', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.query_time).to.be.below(1.0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"MorningAI的定價方案是什麼？\",\n  \"limit\": 5,\n  \"threshold\": 0.7\n}"
            },
            "url": {
              "raw": "{{base_url}}/vector/search",
              "host": ["{{base_url}}"],
              "path": ["vector", "search"]
            }
          }
