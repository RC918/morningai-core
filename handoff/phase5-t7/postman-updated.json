            "url": {
              "raw": "{{base_url}}/vector/search",
              "host": ["{{base_url}}"],
              "path": ["vector", "search"]
            }
          }
        }
      ]
    },
    {
      "name": "💬 增強聊天系統",
      "item": [
        {
          "name": "增強聊天 - 定價問題 (RAG)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('回應類型為 RAG', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.response_type).to.eql('rag');",
                  "});",
                  "",
                  "pm.test('包含知識來源', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.sources).to.be.an('array');",
                  "    pm.expect(responseJson.sources.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('信心度 > 0.8', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.confidence).to.be.above(0.8);",
                  "});",
                  "",
                  "pm.test('處理時間 < 3秒', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.processing_time).to.be.below(3.0);",
