          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const responseJson = pm.response.json();",
                  "    pm.collectionVariables.set('evaluation_id', responseJson.evaluation_id);",
                  "    console.log('📊 已保存 evaluation_id:', responseJson.evaluation_id);",
