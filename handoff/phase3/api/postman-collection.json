  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// 在每個請求前檢查是否需要 access_token",
          "if (pm.request.headers.has('Authorization')) {",
          "    const token = pm.collectionVariables.get('access_token');",
          "    if (!token) {",
          "        console.log('Warning: No access token found. Please login first.');",
          "    }",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// 全局測試腳本",
          "pm.test('Response time is less than 5000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "pm.test('Response has correct Content-Type', function () {",
          "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});",
          "",
          "// 檢查速率限制標頭",
          "if (pm.response.headers.has('X-RateLimit-Limit')) {",
          "    console.log('Rate Limit:', pm.response.headers.get('X-RateLimit-Limit'));",
          "    console.log('Rate Remaining:', pm.response.headers.get('X-RateLimit-Remaining'));",
          "}"
        ]
      }
    }
  ]
}

