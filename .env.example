# ===========================================
# MorningAI Core Environment Variables
# ===========================================
# 複製此文件為 .env 並填入實際值

# ===========================================
# 應用程序基本配置
# ===========================================
APP_NAME=morningai-core
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here

# ===========================================
# 數據庫配置
# ===========================================
# PostgreSQL 主數據庫
DATABASE_URL=postgresql://morningai:morningai_password@localhost:5432/morningai_dev
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30

# 測試數據庫
TEST_DATABASE_URL=postgresql://morningai:morningai_password@localhost:5432/morningai_test

# ===========================================
# Redis 配置
# ===========================================
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_TIMEOUT=5

# ===========================================
# JWT 認證配置
# ===========================================
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# 外部 API 配置
# ===========================================
# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token-here
LINE_CHANNEL_SECRET=your-line-channel-secret-here
LINE_WEBHOOK_URL=https://your-domain.com/webhook/line

# ===========================================
# 安全配置
# ===========================================
# CORS 設定
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend-domain.com
CORS_ALLOW_CREDENTIALS=true

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ===========================================
# 文件存儲配置
# ===========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB

# ===========================================
# 電子郵件配置
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
EMAIL_FROM_NAME=MorningAI
EMAIL_FROM_ADDRESS=noreply@morningai.com

# ===========================================
# 監控與日誌配置
# ===========================================
# Sentry 錯誤追蹤
SENTRY_DSN=https://your-sentry-dsn-here

# 日誌配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===========================================
# 功能開關
# ===========================================
FEATURE_CHAT_ENABLED=true
FEATURE_REFERRAL_ENABLED=true
FEATURE_CMS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true

# ===========================================
# 前端配置
# ===========================================
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development
VITE_ENABLE_MOCK=false

# ===========================================
# 測試配置
# ===========================================
PYTEST_TIMEOUT=30
TEST_PARALLEL=true

# ===========================================
# 開發工具配置
# ===========================================
HOT_RELOAD=true
DOCS_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc

