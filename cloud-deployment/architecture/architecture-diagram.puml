@startuml MorningAI-Cloud-Architecture
!theme aws-orange
!include <awslib/AWSCommon>
!include <awslib/Compute/all>
!include <awslib/Database/all>
!include <awslib/Storage/all>
!include <awslib/NetworkingContentDelivery/all>
!include <awslib/SecurityIdentityCompliance/all>

title MorningAI Core - 雲端架構圖 (D+3)

skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Arial"
skinparam defaultFontSize 12

' Define colors
!define GITHUB_COLOR #24292e
!define RENDER_COLOR #46e3b7
!define SUPABASE_COLOR #3ecf8e
!define MONITORING_COLOR #ff6b6b

' Developer section
rectangle "開發者" as dev {
  actor "Developer" as developer
  note right of developer
    • 推送代碼到 main 分支
    • 觸發部署流程
    • 監控系統狀態
  end note
}

' GitHub section
rectangle "GitHub" as github <<GITHUB_COLOR>> {
  component "Repository" as repo {
    [Source Code]
    [Dockerfile]
    [CI/CD Workflows]
  }
  
  component "GitHub Actions" as actions {
    [Build & Test]
    [Security Scan]
    [Deploy to Staging]
    [Run Evaluation]
  }
  
  component "GHCR" as ghcr {
    [Container Images]
    [morningai-core:staging]
    [morningai-core:latest]
  }
  
  component "Environments" as envs {
    [Staging Secrets]
    [Production Secrets]
    [Environment Variables]
  }
}

' Render.com section
rectangle "Render.com" as render <<RENDER_COLOR>> {
  component "Web Services" as web {
    [FastAPI App (Staging)]
    [FastAPI App (Production)]
  }
  
  component "Redis Services" as redis {
    [Redis Cache (Staging)]
    [Redis Cache (Production)]
  }
  
  note right of web
    • Docker 容器運行
    • 自動擴展
    • SSL 終端
    • Health Check
  end note
}

' Supabase section
rectangle "Supabase" as supabase <<SUPABASE_COLOR>> {
  component "PostgreSQL" as postgres {
    [Database (Staging)]
    [Database (Production)]
    [pgvector Extension]
  }
  
  component "Auth & API" as auth {
    [Row Level Security]
    [Real-time API]
    [Auto-generated APIs]
  }
  
  note right of postgres
    • 自動備份
    • 連接池
    • 向量搜索優化
    • 多租戶支援
  end note
}

' Monitoring section
rectangle "監控與觀測" as monitoring <<MONITORING_COLOR>> {
  component "OpenTelemetry" as otel {
    [Traces]
    [Metrics]
    [Logs]
  }
  
  component "Sentry" as sentry {
    [Error Tracking]
    [Performance Monitoring]
    [Release Health]
  }
  
  component "Grafana" as grafana {
    [Dashboard]
    [Alerts]
    [P95 Response Time]
    [RAG Hit Rate]
    [Error Rate]
  }
}

' External services
rectangle "外部服務" as external {
  component "OpenAI" as openai {
    [GPT-4 API]
    [Embeddings API]
  }
  
  component "Notification" as notify {
    [Telegram Bot API]
    [LINE Messaging API]
  }
}

' Connections
developer --> repo : "git push"
repo --> actions : "trigger"
actions --> ghcr : "push image"
actions --> web : "deploy"
ghcr --> web : "pull image"

web --> postgres : "database queries"
web --> redis : "caching"
web --> openai : "AI requests"
web --> notify : "push notifications"

web --> otel : "telemetry"
otel --> sentry : "errors"
otel --> grafana : "metrics"

actions --> envs : "read secrets"
envs --> web : "environment variables"

' Data flow annotations
note top of actions
  **CI/CD Pipeline**
  1. Code push triggers workflow
  2. Run tests & security scans
  3. Build Docker image
  4. Push to GHCR
  5. Deploy to Render
  6. Run health checks
  7. Execute evaluation tests
end note

note bottom of web
  **API Features**
  • JWT Authentication
  • RAG + GPT Integration
  • Vector Search (pgvector)
  • Rate Limiting (Redis)
  • Multi-tenant Support
  • Real-time Chat
end note

note left of postgres
  **Database Features**
  • PostgreSQL 15+
  • pgvector for embeddings
  • Row Level Security
  • Automatic backups
  • Connection pooling
  • Migration support
end note

' Performance targets
note right of monitoring
  **SLA Targets**
  • P95 Response Time: <3s
  • Error Rate: <1%
  • RAG Hit Rate: >90%
  • Uptime: >99.9%
  • Accuracy: >95%
end note

' Security annotations
note bottom of envs
  **Security Measures**
  • Secrets in GitHub Environments
  • Non-root container execution
  • HTTPS/TLS encryption
  • JWT token authentication
  • Rate limiting & DDoS protection
  • Audit logging
end note

@enduml

